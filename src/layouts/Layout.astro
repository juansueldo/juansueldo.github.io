---
import { ViewTransitions } from "astro:transitions"
interface Props {
  title: string
  description: string,
  lang: string
}
const { description, title, lang } = Astro.props
---
<!doctype html>
<html lang={lang} class="scroll-smooth">
	<script is:inline>
		const theme = localStorage.getItem('theme') || 'system';
		if (theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
		  document.documentElement.classList.add('dark');
		}
	  </script>
	  <!-- <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" is:inline async defer></script>-->
	<head>
		<meta charset="UTF-8" />
		<title>{title}</title>
        <meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="google-site-verification" content="i6BnF5EZmwyr49RbT4goT7AVN_hTk0r3qCfBgNQAj6A" />
		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={`https://juansueldo.dev/${lang}`} />
		<meta property="og:image" content="https://juansueldo.dev/thumbnail/thumbnail_light.png" />
		<meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
		<meta property="og:site_name" content="Juan Sueldo" />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content="https://juansueldo.dev/thumbnail/thumbnail_light.png" />
		<ViewTransitions />
	</head>
	<body class="bg-[#f8f7fa] dark:bg-[#111] flex flex-col min-h-screen justify-center content-center">
		
		<slot />
		
		<style is:global>
			:root {
				color-scheme: light dark;
		  		--main-color: #0af019;
		  		--highlight-color: #0088ff;
				--text-light: #111;
			    --text-dark: #e5e7eb;
			
			    --success-main: #0af019;
			    --success-highlight: #0088ff;
			
			    --danger-main: #ff0000;
			    --danger-highlight: #f55d5d;
			
			    --info-main: #38bdf8;
			    --info-highlight: #6366f1;
			}
		
			.hightlight-text{
		  		background: linear-gradient(45deg, var(--main-color), var(--highlight-color));
		  		-webkit-background-clip: text;
		  		-webkit-text-fill-color: transparent;
			}
			.dark .hightlight-text{
				background: linear-gradient(45deg, var(--main-color), var(--highlight-color));
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
			}
		
			.dark .reflect-below {
		  		-webkit-box-reflect: below -25px -webkit-gradient(linear, left top, left bottom, from(transparent), to(rgba(255, 255, 255, 0.3)));
			}
		
			.reflect-below {
		  		-webkit-box-reflect: below -25px -webkit-gradient(linear, left top, left bottom, from(transparent), to(rgba(235, 15, 15, 0.61)));
			}

			.scrolled {
		  		background: rgba(255, 255, 255, 0.05);
				backdrop-filter: blur(10px);
				box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
				position: fixed;
				width: 100%;
				top: 0;
				left: 0;
				z-index: 9999;
			}
		
			@keyframes animate {
			  0% {
				transform: rotate(0deg);
			  }
			  100% {
				transform: rotate(360deg);
			  }
			}
		
			.box-before {
			  content: "";
			  position: absolute;
			  background: linear-gradient(var(--highlight-color), var(--main-color));
			  animation: animate 4s linear infinite;
			}
			
			.box-after {
			  content: "";
			  position: absolute;
			  inset: 4px;
			  border-radius: 5px;
			}
			.btn-hover{
				background: linear-gradient(45deg, var(--main-color), var(--highlight-color));
				animation: animate 4s linear infinite;
			}
			.group:hover .btn-before {
	  			@apply btn-hover;
			}
	
			.btn-before{
	    		  content: "";
	                  position: absolute;
	  		}
			.field-group {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}
	
			.form-input {
			  --input-main: var(--info-main);
			  --input-highlight: var(--info-highlight);
			
			  padding: 0.75rem;
			  border-radius: 0.75rem;
			  border: 2px solid transparent;
			  width: 100%;
			  font-size: 1rem;
			
			  background:
			    linear-gradient(var(--bg-light), var(--bg-light)) padding-box,
			    linear-gradient(45deg, transparent, transparent) border-box;
			
			  color: var(--text-light);
			  outline: none;
			  transition: 0.25s;
			}
	
			.form-input::placeholder {
  color: color-mix(in srgb, var(--text-light) 50%, transparent);
}

.dark .form-input::placeholder {
  color: color-mix(in srgb, var(--text-dark) 50%, transparent);
}
	
	
			.form-input.input-error {
				border-color: #ef4444;
				box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
			}
	
			.field-error {
				font-size: 0.78rem;
				color: #dc2626;
				min-height: 1rem;
				padding-left: 2px;
			}
	
			.dark .form-input {
			  background:
			    linear-gradient(var(--bg-dark), var(--bg-dark)) padding-box,
			    linear-gradient(45deg, transparent, transparent) border-box;
			
			  color: var(--text-dark);
			}
	
			input:-webkit-autofill,
			textarea:-webkit-autofill {
				-webkit-box-shadow: 0 0 0 1000px #fff inset !important;
				-webkit-text-fill-color: #1b1b1b !important;;
			}
	
			.dark input:-webkit-autofill,
			.dark textarea:-webkit-autofill {
				-webkit-box-shadow: 0 0 0 1000px #1b1b1b inset !important;
				-webkit-text-fill-color: #fff !important;
			}
	
			.form-input:focus {
  background:
    linear-gradient(var(--bg-light), var(--bg-light)) padding-box,
    linear-gradient(45deg, var(--input-main), var(--input-highlight)) border-box;

  box-shadow: 0 0 0 2px color-mix(in srgb, var(--input-main) 25%, transparent);
}

.dark .form-input:focus {
  background:
    linear-gradient(var(--bg-dark), var(--bg-dark)) padding-box,
    linear-gradient(45deg, var(--input-main), var(--input-highlight)) border-box;
}
	.form-input.input-success {
  --input-main: var(--success-main);
  --input-highlight: var(--success-highlight);
}
.form-input.input-error {
  --input-main: var(--danger-main);
  --input-highlight: var(--danger-highlight);
}
			.dark .field-error {
				color: #f87171;
			}
			@keyframes toast-in {
				from { opacity: 0; transform: translateX(20px); }
				to   { opacity: 1; transform: translateX(0); }
			}
			@keyframes spin {
				to { transform: rotate(360deg); }
			}
			.toast-spinner {
				width: 10px; height: 10px;
				border: 1.5px solid currentColor;
				border-top-color: transparent;
				border-radius: 50%;
				animation: spin 0.7s linear infinite;
				opacity: 0.6;
	  		}
			toast {
			  --toast-main: #999;
			  --toast-highlight: #666;
			
			  position: fixed;
			  bottom: 24px;
			  right: 24px;
			
			  display: flex;
			  flex-direction: column;
			  gap: 6px;
			
			  padding: 14px 16px;
			  border-radius: 12px;
			  border: 2px solid transparent;
			
			  background:
			    linear-gradient(var(--bg-light), var(--bg-light)) padding-box,
			    linear-gradient(45deg, var(--toast-main), var(--toast-highlight)) border-box;
			
			  color: var(--text-light);
			
			  box-shadow: 0 10px 25px rgba(0,0,0,0.15);
			  z-index: 9999;
			
			  animation: toast-in 0.3s ease;
			
			  /* 🔥 reflect */
			  -webkit-box-reflect: below -20px -webkit-gradient(
			    linear,
			    left top,
			    left bottom,
			    from(transparent),
			    to(color-mix(in srgb, var(--toast-main) 40%, transparent))
			  );
			}
			
			.dark .toast {
			  background:
			    linear-gradient(var(--bg-dark), var(--bg-dark)) padding-box,
			    linear-gradient(45deg, var(--toast-main), var(--toast-highlight)) border-box;
			
			  color: var(--text-dark);
			
			  -webkit-box-reflect: below -20px -webkit-gradient(
			    linear,
			    left top,
			    left bottom,
			    from(transparent),
			    to(rgba(255,255,255,0.25))
			  );
			}
			
			/* HEADER */
			.toast-header {
			  display: flex;
			  align-items: center;
			  gap: 10px;
			}
			
			.toast-icon {
			  display: flex;
			  align-items: center;
			  justify-content: center;
			
			  width: 22px;
			  height: 22px;
			  border-radius: 50%;
			
			  color: var(--toast-main);
			  background: color-mix(in srgb, var(--toast-main) 20%, transparent);
			}
			
			.toast-title {
			  font-weight: bold;
			  color: var(--toast-main);
			}
			
			.toast-desc {
			  font-size: 14px;
			  opacity: 0.85;
			}
			
			/* TIPOS */
			.toast-success {
			  --toast-main: var(--success-main);
			  --toast-highlight: var(--success-highlight);
			}
			
			.toast-danger {
			  --toast-main: var(--danger-main);
			  --toast-highlight: var(--danger-highlight);
			}
			
			.toast-info {
			  --toast-main: var(--info-main);
			  --toast-highlight: var(--info-highlight);
			}
			
			/* ANIMACIÓN */
			@keyframes toast-in {
			  from {
			    transform: translateY(20px);
			    opacity: 0;
			  }
			  to {
			    transform: translateY(0);
			    opacity: 1;
			  }
			}
		</style>
	</body>
</html>

