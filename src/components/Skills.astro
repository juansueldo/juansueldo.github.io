---
import SkillCategoryIcon from "./SkillCategoryIcon.astro";
import TechnologyBadges from "./TechnologyBadges.astro";

interface SkillGroup {
  title: string;
  icon: string;
  technologies: string[];
}

interface Props {
  title: string;
  groups: SkillGroup[];
}

const { title, groups } = Astro.props;
---

<section
  id="technology-skills"
  class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto w-full max-w-6xl">
    <h2 class="section-title reveal mb-12 text-3xl font-bold text-black dark:text-white sm:text-4xl">
      {title}
    </h2>

  <div class="container mx-auto grid grid-cols-1 gap-6 md:grid-cols-2">
    {groups.map((group) => (
      <article class="reveal rounded-2xl bg-gray-100 p-6 shadow-lg dark:bg-[#1b1b1b]">
        <div class="mb-5 flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <span class="flex size-10 shrink-0 items-center justify-center rounded-lg border border-emerald-400/20 bg-emerald-400/10 text-emerald-500 shadow-[0_0_18px_rgba(16,185,129,0.12)] dark:text-emerald-400">
              <SkillCategoryIcon type={group.icon} class="size-5" />
            </span>
            <h3 class="text-xl font-semibold text-gray-800 dark:text-white">
              {group.title}
            </h3>
          </div>
        </div>
        <TechnologyBadges technologies={group.technologies} />
      </article>
    ))}
  </div>
  </div>  
</section>
