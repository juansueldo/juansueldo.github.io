---
interface Props {
  width: string
  id: string
  text: any
  hightlight_text: any
  url?: string
  btnstyle?: string
  as?: 'a' | 'button'
  type?: 'button' | 'submit'
}

const {
  width,
  id,
  text,
  hightlight_text,
  url = '#',
  btnstyle = 'box',
  as = 'a',
  type = 'button'
} = Astro.props;

const baseClass = `group w-${width} card reveal box relative p-4 flex justify-center items-center bg-[#f8f7fa] dark:bg-[#111] overflow-hidden -skew-y-1 mb-2.5 mt-2.5 rounded cursor-pointer reflect-below dark:reflect-below`;
---

{as === 'a' ? (
  <a
    id={id}
    href={url}
    target="_blank"
    class={baseClass}
  >
    <div class={`absolute ${btnstyle}-before h-[600%] w-[30px] group-hover:btn-hover`}></div>
    <div class="absolute box-after bg-[#111] dark:bg-[#f8f7fa]"></div>

    <h1 class="relative text-[#f8f7fa] dark:text-[#111] flex gap-1 text-base font-bold z-10">
      <slot />
      {text} <span class="hightlight-text">{hightlight_text}</span>
    </h1>
  </a>
) : (
  <button
    id={id}
    type={type}
    class={baseClass}
  >
    <div class={`absolute ${btnstyle}-before h-[600%] w-[30px] group-hover:btn-hover`}></div>
    <div class="absolute box-after bg-[#111] dark:bg-[#f8f7fa]"></div>

    <h1 class="relative text-[#f8f7fa] dark:text-[#111] flex gap-1 text-base font-bold z-10">
      <slot />
      {text} <span class="hightlight-text">{hightlight_text}</span>
    </h1>
  </button>
)}