---
interface Props {
  width: 'full' | 'fit' | '50%'
  id: string
  text: any
  hightlight_text: any
  url?: string
  btnstyle?: string
  as?: 'a' | 'button'
  type?: 'button' | 'submit'
}

const {
  width,
  id,
  text,
  hightlight_text,
  url = '#',
  btnstyle = 'box',
  as = 'a',
  type = 'button'
}: Props = Astro.props;

const widthClass = {
  full: 'w-full',
  fit: 'w-fit',
  '50%': 'w-full sm:w-1/2'
}[width];

const baseClass = `group ${widthClass} card reveal box relative my-2.5 flex min-h-14 items-center justify-center overflow-hidden rounded bg-[#f8f7fa] px-5 py-3 text-center cursor-pointer -skew-y-1 reflect-below dark:bg-[#111] dark:reflect-below`;
---

{as === 'a' ? (
  <a
    id={id}
    href={url}
    target="_blank"
    class={baseClass}
  >
    <div class={`absolute ${btnstyle}-before h-[600%] w-[30px] group-hover:btn-hover`}></div>
    <div class="absolute box-after bg-[#111] dark:bg-[#f8f7fa]"></div>

    <span class="relative z-10 block max-w-full text-sm font-bold leading-snug text-[#f8f7fa] dark:text-[#111] sm:text-base">
      <slot />{text}{text && hightlight_text && ' '}<span class="hightlight-text">{hightlight_text}</span>
    </span>
  </a>
) : (
  <button
    id={id}
    type={type}
    class={baseClass}
  >
    <div class={`absolute ${btnstyle}-before h-[600%] w-[30px] group-hover:btn-hover`}></div>
    <div class="absolute box-after bg-[#111] dark:bg-[#f8f7fa]"></div>

    <span class="relative z-10 block max-w-full text-sm font-bold leading-snug text-[#f8f7fa] dark:text-[#111] sm:text-base">
      <slot />{text}{text && hightlight_text && ' '}<span class="hightlight-text">{hightlight_text}</span>
    </span>
  </button>
)}
