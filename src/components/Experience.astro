---
import Cards from "./Cards.astro";
import TechnologyBadges from "./TechnologyBadges.astro";

interface Job {
  start: string;
  end: string;
  position: string;
  company: string;
  description: string;
  technologies: string[];
}

interface Props {
  title: string;
  experience: Job[];
}

const { title, experience }: Props = Astro.props;
---

<section id="experience" class="experience-section px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto w-full max-w-6xl">
    <h2 class="section-title reveal mb-12 text-3xl font-bold text-black dark:text-white sm:text-4xl">
      {title}
    </h2>

    <ol class="experience-timeline reveal" aria-label={title}>
      {experience.map((job) => (
        <li class="experience-item reveal">
          <div class="experience-marker" aria-hidden="true"></div>

          <time class="text-black dark:text-white text-xs pt-2">
            {job.start} – {job.end}
          </time>

          <Cards variant="experience">
            <h3 class="experience-heading text-black dark:text-white">
              <span class="experience-company text-black dark:text-white">{job.company}</span>
              <span class="experience-separator text-black dark:text-white" aria-hidden="true">|</span>
              <span class="experience-position text-black dark:text-white">{job.position}</span>
            </h3>

            <p class="experience-description text-black dark:text-white">
              {job.description}
            </p>

            <TechnologyBadges technologies={job.technologies} class="mt-4" />
          </Cards>
        </li>
      ))}
    </ol>
  </div>
</section>
