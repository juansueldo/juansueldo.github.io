---
import HiglightButton from "./HiglightButton.astro";
import Toast from "./Toast.astro";
import Cards from "./Cards.astro";

interface Props {
  title: string,
  name_placeholder: string,
  mail_placeholder: string,
  message_placeholder: string,
  button_initial: string,
  button_highlight: string,
  sending: string,
  success: string,
  error: string,
  errName: string,
  errEmail: string,
  errMessage: string,
  intro_title: string,
  intro_description: string,
  intro_cta: string,
  email: string,
  location: string,
  response: string
}
const {
  title, name_placeholder, mail_placeholder, message_placeholder,
  button_initial, button_highlight, sending, success, error,
  errName, errEmail, errMessage, intro_title, intro_description,
  intro_cta, email, location, response
}: Props = Astro.props;

---

<Toast sending={sending} success={success} error={error} />

<section id="contact" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto grid w-full max-w-6xl gap-10 lg:grid-cols-5 lg:items-start lg:gap-12">
    <div class="reveal lg:col-span-2">
      <h2 class="section-title mb-8 text-3xl font-bold text-black dark:text-white sm:text-4xl">{title}</h2>
      <h3 class="hightlight-text text-lg font-bold">{intro_title}</h3>
      <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">{intro_description}</p>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">{intro_cta}</p>

      <!-- 
      <ul class="mt-7 grid gap-4 text-sm text-slate-600 dark:text-slate-300">
        <li class="flex items-center gap-3"><span class="hightlight-text" aria-hidden="true">✉</span><a href={`mailto:${email}`} class="hover:underline">{email}</a></li>
        <li class="flex items-center gap-3"><span class="hightlight-text" aria-hidden="true">⌖</span><span>{location}</span></li>
        <li class="flex items-center gap-3"><span class="hightlight-text" aria-hidden="true">◉</span><span>{response}</span></li>
      </ul>
      -->
    </div>

    <div class="lg:col-span-3">
      <Cards variant="contact">
        <form id="contact-form" class="flex w-full flex-col gap-4" novalidate>
          <input type="text" name="website" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-4 sm:grid-cols-2">
            <div class="field-group">
              <input type="text" name="name" id="field-name" placeholder={name_placeholder} autocomplete="name" class="form-input dark:bg-[#1b1b1b]" aria-describedby="error-name" />
              <span id="error-name" class="field-error" role="alert"></span>
            </div>

            <div class="field-group">
              <input type="email" name="email" id="field-email" placeholder={mail_placeholder} autocomplete="email" class="form-input" aria-describedby="error-email" />
              <span id="error-email" class="field-error" role="alert"></span>
            </div>
          </div>

          <div class="field-group">
            <textarea name="message" id="field-message" placeholder={message_placeholder} rows="5" class="form-input" aria-describedby="error-message"></textarea>
            <span id="error-message" class="field-error" role="alert"></span>
          </div>

          <HiglightButton as="button" type="submit" width="full" id="send-mail" text={button_initial} hightlight_text={button_highlight} btnstyle="btn" />
        </form>
      </Cards>
    </div>

    <div
      id="form-i18n"
      data-err-name={errName}
      data-err-email={errEmail}
      data-err-message={errMessage}
      style="display:none"
    ></div>
  </div>
</section>


<script>
  import { showToast } from '../utils/toast.ts';

  const i18nEl = document.getElementById('form-i18n')!;
  const errName    = i18nEl.dataset.errName!;
  const errEmail   = i18nEl.dataset.errEmail!;
  const errMessage = i18nEl.dataset.errMessage!;

  interface FieldRule { 
    id: string; 
    errorId: string; 
    test: (val: string) => string | null; 
  }

  const rules: FieldRule[] = [
    { id: 'field-name', errorId: 'error-name', test: (v) => v.trim().length < 2 ? errName : null },
    { id: 'field-email', errorId: 'error-email', test: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) ? null : errEmail },
    { id: 'field-message', errorId: 'error-message', test: (v) => v.trim().length < 1 ? errMessage : null },
  ];

  function setFieldError(rule: FieldRule, msg: string | null) {
    const input = document.getElementById(rule.id) as HTMLElement | null;
    const error = document.getElementById(rule.errorId);
    if (input && error) {
      if (msg) {
        input.classList.add('input-error');
        error.textContent = msg;
      } else {
        input.classList.remove('input-error');
        error.textContent = '';
      }
    }
  }

  // --- NUEVA LÓGICA DE VALIDACIÓN EN TIEMPO REAL ---
  rules.forEach(rule => {
    const input = document.getElementById(rule.id);
    if (input) {
      input.addEventListener('input', () => {
        const val = (input as HTMLInputElement).value;
        const msg = rule.test(val);
        setFieldError(rule, msg);
      });
    }
  });

  function validateAll(): boolean {
    let isValid = true;
    rules.forEach(rule => {
      const val = (document.getElementById(rule.id) as HTMLInputElement)?.value || '';
      const msg = rule.test(val);
      setFieldError(rule, msg);
      if (msg) isValid = false;
    });
    return isValid;
  }

  // ── Form Submission ────────────────────────────────────────────────────────
  let isSubmitting = false;

  async function submitForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    if (isSubmitting) return;

    isSubmitting = true;
    showToast('loading');

    const formData = new FormData(form);
    
    if (formData.get('website')) return;

    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      message: formData.get('message'),
      lang: document.documentElement.lang || 'en',
    };

    try {
      const res = await fetch('https://ipinfo-tawny-psi.vercel.app/api/mailer', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (!res.ok) throw new Error();

      showToast('success');
      form.reset();
    } catch {
      showToast('error');
    } finally {
      isSubmitting = false;
    }
  }

  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (validateAll()) {
      submitForm();
    }
  });
</script>
